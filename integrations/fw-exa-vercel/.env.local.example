# Exa API Key — get yours at https://exa.ai
EXA_API_KEY=your_exa_api_key_here

# Fireworks AI API Key — get yours at https://fireworks.ai
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Vercel AI Gateway — OPTIONAL for local dev, required for production monitoring
# Find your team slug: Vercel dashboard → your team → Settings → General → "Team slug"
# Example: if your team URL is vercel.com/acme, the slug is "acme"
# When set, all Fireworks calls route through gateway.ai.vercel.app for logging & rate limiting
# Leave unset to call Fireworks directly (works fine for local testing)
VERCEL_TEAM_SLUG=
